type Timestamp = int;
type SubmitResult = 
 variant {
   err: text;
   ok;
 };
type ContactMessage = 
 record {
   email: text;
   id: nat;
   message: text;
   name: text;
   timestamp: Timestamp;
 };
service : {
  getMessages: () -> (vec ContactMessage) query;
  submitContact: (name: text, email: text, message: text) -> (SubmitResult);
}
